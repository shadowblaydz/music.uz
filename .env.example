# Telegram token from @BotFather.
# Do not commit the real token. Put it in a local .env file instead.
# Railway deploy: add this value in Railway Variables, not in GitHub.
BOT_TOKEN=123456789:REPLACE_WITH_YOUR_REAL_TOKEN

# SQLite database path. The bot creates this file automatically.
DATABASE_PATH=data/musiqa_bot.sqlite3

# Optional: "INFO", "DEBUG", "WARNING", "ERROR"
LOG_LEVEL=INFO

# Comma-separated Telegram user IDs that can open /admin.
# Send /id to the bot to see your Telegram user ID.
ADMIN_IDS=

# Optional: AudD token for Shazam-like audio recognition.
# Get one from https://dashboard.audd.io/
AUDD_API_TOKEN=
